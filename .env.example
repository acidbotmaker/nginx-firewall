# Random secret used to sign admin session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Where the admin UI/API listens on the host. Default binds to loopback;
# put a TLS reverse proxy in front for remote access.
ADMIN_BIND=127.0.0.1:8080

# App environment. Set to DEV to enable Swagger UI at /docs and ReDoc at /redoc.
# Anything else (default: PROD) disables them.
APP_ENV=PROD

# Services (upstream host, protocol, external + target ports) are no longer
# configured here — add and manage them from the admin UI or the
# /api/services endpoints. Each service gets its own IP allowlist.
