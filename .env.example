# Upstream service the firewall protects.
UPSTREAM_HOST=host.docker.internal

# Internal ports the upstream service actually listens on
# (what nginx forwards traffic to).
TARGET_TCP=2222
TARGET_UDP=51820

# Public ports nginx listens on (what clients on the internet hit).
# Can be the same as TARGET_* or different (e.g. listen on 443, forward to 2222).
EXTERNAL_TCP=2222
EXTERNAL_UDP=51820

# Random secret used to sign admin session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Where the admin UI/API listens on the host. Default binds to loopback;
# put a TLS reverse proxy in front for remote access.
ADMIN_BIND=127.0.0.1:8080
